generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                String           @id @default(uuid())
  email             String           @unique
  name              String
  passwordHash      String
  avatar            String?
  role              UserRole         @default(REPORTER)
  department        String?
  expertise         String           @default("[]")
  preferredLanguage ContentLanguage? @default(TRADITIONAL_CHINESE_HK)
  isActive          Boolean          @default(true)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  // Relations
  stories          Story[]           @relation("ReporterStories")
  editedStories    Story[]           @relation("EditorStories")
  articles         Article[]         @relation("AuthorArticles")
  editedArticles   Article[]         @relation("EditorArticles")
  aiOperations     AIOperation[]
  autoPublishTasks AutoPublishTask[]

  @@map("users")
}

model Story {
  id              String           @id @default(uuid())
  title           String
  description     String?          @db.Text
  angle           String?
  status          ArticleStatus    @default(DRAFT)
  priority        Int              @default(0)
  tags            String           @default("[]")
  contentLanguage ContentLanguage? @default(TRADITIONAL_CHINESE_HK)
  deadline        DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  // Relations
  reporterId String
  reporter   User      @relation("ReporterStories", fields: [reporterId], references: [id])
  editorId   String?
  editor     User?     @relation("EditorStories", fields: [editorId], references: [id])
  articles   Article[]

  @@map("stories")
}

model Article {
  id               String           @id @default(uuid())
  title            String
  subtitle         String?
  content          String           @db.LongText
  excerpt          String?          @db.Text
  status           ArticleStatus    @default(DRAFT)
  tags             String           @default("[]")
  platforms        String           @default("[]")
  coverImage       String?
  aiGeneratedParts String           @default("[]")
  version          Int              @default(1)
  contentLanguage  ContentLanguage? @default(TRADITIONAL_CHINESE_HK)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  publishedAt      DateTime?

  // Relations
  storyId           String?
  story             Story?            @relation(fields: [storyId], references: [id], onDelete: SetNull)
  authorId          String
  author            User              @relation("AuthorArticles", fields: [authorId], references: [id])
  editorId          String?
  editor            User?             @relation("EditorArticles", fields: [editorId], references: [id])
  versions          ArticleVersion[]
  aiOperations      AIOperation[]
  platformPublishes PlatformPublish[]

  @@map("articles")
}

model PlatformPublish {
  id             String        @id @default(uuid())
  articleId      String
  article        Article       @relation(fields: [articleId], references: [id], onDelete: Cascade)
  platform       String
  status         PublishStatus @default(DRAFT)
  adaptedTitle   String?
  adaptedContent String?       @db.Text
  adaptedExcerpt String?       @db.Text
  adaptedTags    String        @default("[]")
  coverImages    String        @default("[]")
  scheduledAt    DateTime?
  publishedAt    DateTime?
  publishedUrl   String?       @db.VarChar(500)
  notes          String?       @db.Text
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([articleId, platform])
  @@map("platform_publishes")
}

model ArticleVersion {
  id        String   @id @default(uuid())
  content   String   @db.LongText
  title     String
  version   Int
  createdAt DateTime @default(now())

  // Relations
  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@map("article_versions")
}

model AIOperation {
  id         String    @id @default(uuid())
  agentType  AgentType
  action     String
  prompt     String    @db.Text
  result     String?   @db.Text
  model      String
  tokensUsed Int?
  durationMs Int
  createdAt  DateTime  @default(now())

  // Relations
  articleId String?
  article   Article? @relation(fields: [articleId], references: [id])
  createdBy String
  user      User     @relation(fields: [createdBy], references: [id])

  @@map("ai_operations")
}

enum ContentLanguage {
  SIMPLIFIED_CHINESE
  TRADITIONAL_CHINESE_HK
  TRADITIONAL_CHINESE_CANTONESE
  ENGLISH
}

enum UserRole {
  REPORTER
  EDITOR
  ADMIN
}

enum ArticleStatus {
  DRAFT
  WRITING
  AI_OPTIMIZING
  PENDING_REVIEW
  IN_REVIEW
  REVISION
  APPROVED
  PUBLISHED
  ARCHIVED
  PIPELINE_FAILED
  AUTO_PUBLISHED
}

enum AgentType {
  STORY
  RESEARCH
  WRITING
  EDITOR
  REVIEW
  VISUAL
  DISTRIBUTE
}

enum PublishStatus {
  DRAFT
  GENERATING
  READY
  SCHEDULED
  PUBLISHED
  FAILED
}

enum TopicStatus {
  OPEN
  ADOPTED
  ARCHIVED
}

model TrendingTopic {
  id              String      @id @default(uuid())
  title           String
  description     String?     @db.Text
  source          String?
  heatScore       Int         @default(0)
  tags            String      @default("[]")
  status          TopicStatus @default(OPEN)
  suggestedAngles String?     @db.Text
  createdBy       String
  adoptedStoryId  String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@map("trending_topics")
}

// ─── Auto-Publishing Pipeline ───

enum AutoTaskStatus {
  ACTIVE
  PAUSED
  DISABLED
}

enum ScheduleType {
  FIXED_TIME
  INTERVAL
  CRON
}

enum RunStatus {
  RUNNING
  COMPLETED
  PARTIAL
  FAILED
}

enum ArticleRunStatus {
  PENDING
  TOPIC_SELECTED
  RESEARCHED
  DRAFTED
  IMAGED
  SAVED
  PUBLISHED
  FAILED
  WITHDRAWN
}

enum TriggerType {
  SCHEDULED
  MANUAL
}

model AutoPublishTask {
  id             String         @id @default(uuid())
  name           String
  description    String?        @db.Text
  status         AutoTaskStatus @default(PAUSED)
  scheduleType   ScheduleType   @default(FIXED_TIME)
  scheduleConfig String         @db.Text
  topicStrategy  String         @db.Text
  contentConfig  String         @db.Text
  filterConfig   String         @db.Text
  publishConfig  String         @db.Text
  batchSize      Int            @default(1)
  retryConfig    String         @db.Text
  lastRunAt      DateTime?
  nextRunAt      DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // Relations
  createdBy String
  user      User                 @relation(fields: [createdBy], references: [id])
  runs      AutoPublishRun[]
  articles  AutoPublishArticle[]

  @@map("auto_publish_tasks")
}

model AutoPublishRun {
  id            String      @id @default(uuid())
  status        RunStatus   @default(RUNNING)
  startedAt     DateTime    @default(now())
  completedAt   DateTime?
  totalArticles Int         @default(0)
  successCount  Int         @default(0)
  failedCount   Int         @default(0)
  errorLog      String?     @db.Text
  triggerType   TriggerType @default(SCHEDULED)

  // Relations
  taskId   String
  task     AutoPublishTask      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  articles AutoPublishArticle[]

  @@map("auto_publish_runs")
}

model AutoPublishArticle {
  id                String           @id @default(uuid())
  status            ArticleRunStatus @default(PENDING)
  topic             String?
  articleId         String?
  platformPublishId String?
  failedStep        String?
  errorMessage      String?          @db.Text
  retryCount        Int              @default(0)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  // Relations
  runId  String
  run    AutoPublishRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  taskId String
  task   AutoPublishTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("auto_publish_articles")
}

// 紧急杀戮开关单例表（issue #48 P0 修复）
// MySQL 为唯一真源，Redis 仅作缓存以减少 DB 查询
model KillSwitch {
  id        String    @id // 单例 key：'auto-publish'
  enabled   Boolean   @default(false)
  enabledAt DateTime?
  enabledBy String?
  reason    String?   @db.Text
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("kill_switches")
}
