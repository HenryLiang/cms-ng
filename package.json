{
  "name": "cms-ng",
  "version": "1.0.0",
  "private": true,
  "description": "01创作大脑 — AI驱动的内容创作作业系统",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:generate": "cd backend && npx prisma generate",
    "db:migrate": "cd backend && npx prisma migrate dev",
    "db:studio": "cd backend && npx prisma studio",
    "db:seed": "cd backend && npx ts-node prisma/seed.ts"
  },
  "workspaces": [
    "frontend",
    "backend",
    "packages/*"
  ],
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "turbo": "^2.5.0"
  },
  "packageManager": "npm@10.9.0"
}
