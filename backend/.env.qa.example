# QA env — used by Playwright regression suite against cms_ng_qa DB on :3002.
# Inherits most vars from .env; only the differences are listed here.
# Copy to .env.qa and fill real values:  cp .env.qa.example .env.qa
# Load with:  set -a; source .env; source .env.qa; set +a   (or use direnv)

PORT=3002
DATABASE_URL="mysql://USER:PASS@HOST:3306/cms_ng_qa"
APP_BASE_URL="http://localhost:3002"
# Point AuthorStyleService at the repo's data/authors/ regardless of cwd.
AUTHORS_DATA_DIR="<absolute-path-to-repo>/data/authors"
