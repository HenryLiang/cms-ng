generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                String           @id @default(uuid())
  email             String           @unique
  name              String
  passwordHash      String
  avatar            String?
  role              UserRole         @default(REPORTER)
  department        String?
  expertise         String           @default("[]")
  preferredLanguage ContentLanguage? @default(TRADITIONAL_CHINESE_HK)
  isActive          Boolean          @default(true)
  balance           Decimal          @default(0) @db.Decimal(12, 4)
  lastLoginAt       DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  // Relations
  stories             Story[]              @relation("ReporterStories")
  editedStories       Story[]              @relation("EditorStories")
  articles            Article[]            @relation("AuthorArticles")
  editedArticles      Article[]            @relation("EditorArticles")
  aiOperations        AIOperation[]
  autoPublishTasks    AutoPublishTask[]
  topUpRecords        TopUpRecord[]
  billingTransactions BillingTransaction[]
  balanceAlert        BalanceAlert?
  mediaAssets         MediaAsset[]

  @@map("users")
}

model Story {
  id              String           @id @default(uuid())
  title           String           @db.Text
  description     String?          @db.Text
  angle           String?
  status          ArticleStatus    @default(DRAFT)
  priority        Int              @default(0)
  tags            String           @default("[]") @db.VarChar(1000)
  contentLanguage ContentLanguage? @default(TRADITIONAL_CHINESE_HK)
  deadline        DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  // Relations
  reporterId String
  reporter   User      @relation("ReporterStories", fields: [reporterId], references: [id])
  editorId   String?
  editor     User?     @relation("EditorStories", fields: [editorId], references: [id])
  articles   Article[]

  @@map("stories")
}

model Article {
  id               String           @id @default(uuid())
  title            String
  subtitle         String?
  content          String           @db.LongText
  excerpt          String?          @db.Text
  status           ArticleStatus    @default(DRAFT)
  tags             String           @default("[]")
  platforms        String           @default("[]")
  coverImage       String?
  aiGeneratedParts String           @default("[]")
  version          Int              @default(1)
  contentLanguage  ContentLanguage? @default(TRADITIONAL_CHINESE_HK)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  publishedAt      DateTime?

  // Relations
  storyId           String?
  story             Story?            @relation(fields: [storyId], references: [id], onDelete: SetNull)
  authorId          String
  author            User              @relation("AuthorArticles", fields: [authorId], references: [id])
  editorId          String?
  editor            User?             @relation("EditorArticles", fields: [editorId], references: [id])
  versions            ArticleVersion[]
  aiOperations        AIOperation[]
  platformPublishes   PlatformPublish[]
  billingTransactions BillingTransaction[]

  @@map("articles")
}

model PlatformPublish {
  id             String        @id @default(uuid())
  articleId      String
  article        Article       @relation(fields: [articleId], references: [id], onDelete: Cascade)
  platform       String
  status         PublishStatus @default(DRAFT)
  adaptedTitle   String?
  adaptedContent String?       @db.Text
  adaptedExcerpt String?       @db.Text
  adaptedTags    String        @default("[]")
  coverImages    String        @default("[]")
  scheduledAt    DateTime?
  publishedAt    DateTime?
  publishedUrl   String?       @db.VarChar(500)
  notes          String?       @db.Text
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  billingTransaction BillingTransaction?

  @@unique([articleId, platform])
  @@map("platform_publishes")
}

model ArticleVersion {
  id        String   @id @default(uuid())
  content   String   @db.LongText
  title     String
  version   Int
  createdAt DateTime @default(now())

  // Relations
  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@map("article_versions")
}

model AIOperation {
  id         String    @id @default(uuid())
  agentType  AgentType
  action     String
  prompt     String    @db.Text
  result     String?   @db.Text
  model      String
  tokensUsed Int?
  durationMs Int
  createdAt  DateTime  @default(now())

  // Relations
  articleId String?
  article   Article? @relation(fields: [articleId], references: [id])
  createdBy String
  user      User     @relation(fields: [createdBy], references: [id])

  billingTransaction BillingTransaction?

  @@map("ai_operations")
}

enum ContentLanguage {
  SIMPLIFIED_CHINESE
  TRADITIONAL_CHINESE_HK
  TRADITIONAL_CHINESE_CANTONESE
  ENGLISH
}

enum UserRole {
  REPORTER
  EDITOR
  ADMIN
}

enum ArticleStatus {
  DRAFT
  WRITING
  AI_OPTIMIZING
  PENDING_REVIEW
  IN_REVIEW
  REVISION
  APPROVED
  PUBLISHED
  ARCHIVED
  PIPELINE_FAILED
  AUTO_PUBLISHED
}

enum AgentType {
  STORY
  RESEARCH
  WRITING
  EDITOR
  REVIEW
  VISUAL
  DISTRIBUTE
}

enum PublishStatus {
  DRAFT
  GENERATING
  READY
  SCHEDULED
  PUBLISHED
  FAILED
}

enum TopicStatus {
  OPEN
  ADOPTED
  ARCHIVED
}

model TrendingTopic {
  id              String      @id @default(uuid())
  title           String      @db.Text
  description     String?     @db.Text
  source          String?
  heatScore       Int         @default(0)
  tags            String      @default("[]") @db.VarChar(1000)
  status          TopicStatus @default(OPEN)
  suggestedAngles String?     @db.Text
  createdBy       String
  adoptedStoryId  String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@map("trending_topics")
}

// ─── X (Twitter) 数据源 — 热门账号 watch 清单 ───

model TwitterWatchAccount {
  id          String   @id @default(uuid())
  userName    String   @unique // X handle，不含 @
  displayName String?
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("twitter_watch_accounts")
}

// ─── Auto-Publishing Pipeline ───

enum AutoTaskStatus {
  ACTIVE
  PAUSED
  DISABLED
}

enum ScheduleType {
  FIXED_TIME
  INTERVAL
  CRON
}

enum RunStatus {
  RUNNING
  COMPLETED
  PARTIAL
  FAILED
}

enum ArticleRunStatus {
  PENDING
  TOPIC_SELECTED
  RESEARCHED
  DRAFTED
  IMAGED
  SAVED
  PUBLISHED
  FAILED
  WITHDRAWN
}

enum TriggerType {
  SCHEDULED
  MANUAL
}

model AutoPublishTask {
  id             String         @id @default(uuid())
  name           String
  description    String?        @db.Text
  status         AutoTaskStatus @default(PAUSED)
  scheduleType   ScheduleType   @default(FIXED_TIME)
  scheduleConfig String         @db.Text
  topicStrategy  String         @db.Text
  contentConfig  String         @db.Text
  filterConfig   String         @db.Text
  publishConfig  String         @db.Text
  batchSize      Int            @default(1)
  retryConfig    String         @db.Text
  lastRunAt      DateTime?
  nextRunAt      DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // Relations
  createdBy String
  user      User                 @relation(fields: [createdBy], references: [id])
  runs      AutoPublishRun[]
  articles  AutoPublishArticle[]

  @@map("auto_publish_tasks")
}

model AutoPublishRun {
  id            String      @id @default(uuid())
  status        RunStatus   @default(RUNNING)
  startedAt     DateTime    @default(now())
  completedAt   DateTime?
  totalArticles Int         @default(0)
  successCount  Int         @default(0)
  failedCount   Int         @default(0)
  errorLog      String?     @db.Text
  triggerType   TriggerType @default(SCHEDULED)

  // Relations
  taskId   String
  task     AutoPublishTask      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  articles AutoPublishArticle[]

  @@map("auto_publish_runs")
}

model AutoPublishArticle {
  id                String           @id @default(uuid())
  status            ArticleRunStatus @default(PENDING)
  topic             String?
  articleId         String?
  platformPublishId String?
  failedStep        String?
  errorMessage      String?          @db.Text
  retryCount        Int              @default(0)
  executionTrace    String?          @db.LongText
  totalDurationMs   Int?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  // Relations
  runId  String
  run    AutoPublishRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  taskId String
  task   AutoPublishTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("auto_publish_articles")
}

// ─── 计费系统 (Billing System) ───

enum TransactionType {
  TOP_UP
  AI_LLM
  AI_IMAGE
  PUBLISH
  AUTO_PUBLISH
  DATA_FETCH
  REFUND
  ADJUSTMENT
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  ALIPAY
  WECHAT_PAY
  BANK_TRANSFER
  MANUAL
}

enum BillingCategory {
  AI
  PUBLISHING
  OTHER
}

// 计费配置（各操作的单价）
model BillingConfig {
  id        String          @id @default(uuid())
  category  BillingCategory
  itemKey   String
  itemName  String
  unitPrice Decimal         @db.Decimal(12, 4)
  unit      String
  isActive  Boolean         @default(true)
  updatedAt DateTime        @updatedAt
  updatedBy String?

  @@unique([category, itemKey])
  @@map("billing_configs")
}

// 充值记录
model TopUpRecord {
  id              String            @id @default(uuid())
  userId          String
  user            User              @relation(fields: [userId], references: [id])
  amount          Decimal           @db.Decimal(12, 4)
  creditsAdded    Decimal           @db.Decimal(12, 4)
  bonusCredits    Decimal           @db.Decimal(12, 4) @default(0)
  paymentMethod   PaymentMethod
  externalOrderId String?           @db.VarChar(255)
  status          TransactionStatus @default(PENDING)
  paidAt          DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  billingTransaction BillingTransaction?

  @@index([userId, createdAt])
  @@index([status])
  @@map("top_up_records")
}

// 计费流水（核心表，append-only）
model BillingTransaction {
  id                String            @id @default(uuid())
  userId            String
  user              User              @relation(fields: [userId], references: [id])
  type              TransactionType
  category          BillingCategory
  amount            Decimal           @db.Decimal(12, 4)
  balanceAfter      Decimal           @db.Decimal(12, 4)
  description       String            @db.VarChar(500)
  articleId         String?
  article           Article?          @relation(fields: [articleId], references: [id])
  aiOperationId     String?           @unique
  aiOperation       AIOperation?      @relation(fields: [aiOperationId], references: [id])
  platformPublishId String?           @unique
  platformPublish   PlatformPublish?  @relation(fields: [platformPublishId], references: [id])
  topUpRecordId     String?           @unique
  topUpRecord       TopUpRecord?      @relation(fields: [topUpRecordId], references: [id])
  quantity          Decimal?          @db.Decimal(12, 4)
  unitPrice         Decimal?          @db.Decimal(12, 4)
  status            TransactionStatus @default(COMPLETED)
  idempotencyKey    String?           @unique @db.VarChar(255)
  metadata          String?           @db.Text
  createdAt         DateTime          @default(now())

  @@index([userId, createdAt])
  @@index([type, createdAt])
  @@index([articleId])
  @@index([aiOperationId])
  @@map("billing_transactions")
}

// 余额预警配置
model BalanceAlert {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  thresholdAmount Decimal   @db.Decimal(12, 4)
  isEnabled       Boolean   @default(true)
  lastTriggeredAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([userId])
  @@map("balance_alerts")
}

// 紧急杀戮开关单例表（issue #48 P0 修复）
// MySQL 为唯一真源，Redis 仅作缓存以减少 DB 查询
model KillSwitch {
  id        String    @id // 单例 key：'auto-publish'
  enabled   Boolean   @default(false)
  enabledAt DateTime?
  enabledBy String?
  reason    String?   @db.Text
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("kill_switches")
}

// 注册开关单例表 — 管理员控制注册功能的开/关
// 语义与 KillSwitch 相反：enabled=true 表示注册【开放】，默认 true（保持现有行为）
// MySQL 为唯一真源，不读 Redis（注册状态为冷路径，无需缓存）
model RegistrationSwitch {
  id        String    @id // 单例 key：'registration'
  enabled   Boolean   @default(true) // true = 注册开放（与 KillSwitch 语义相反）
  enabledAt DateTime? // 最近一次切换时间（审计）
  enabledBy String?
  reason    String?   @db.Text
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("registration_switches")
}

// ===== 媒体资源管理 =====
// 用户上传 + AI 生成图片统一管理。个人库先行：libraryType 本期仅 PERSONAL；
// TEAM 预留待 Team 实体建立后启用（teamId 字段已预留，零迁移）。
enum MediaSource {
  UPLOAD
  AI_GENERATED
}

enum MediaStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

enum MediaLibraryType {
  PERSONAL
  TEAM
}

model MediaAsset {
  id            String           @id @default(uuid())
  // 存储
  storageKey    String           // COS key（相对 bucket 根，不含前导 /）
  url           String           // 公网访问 URL（含 CDN）
  thumbnailUrl  String?          // 缩略图 URL（COS imageMogr2 拼参生成，零额外存储）
  // 文件元数据
  fileName      String           // 展示用文件名（上传原文件名 / AI 生成命名）
  mimeType      String           // image/jpeg | image/png | image/webp | image/gif
  size          Int              // 字节数
  width         Int?             // 像素
  height        Int?             // 像素
  // 来源
  source        MediaSource      @default(UPLOAD)
  sourceRef     String?          // AI: 关联 aiOperationId；UPLOAD: null
  prompt        String?          @db.Text // AI 生成时的 prompt
  // 元信息
  altText       String?
  title         String?
  description   String?          @db.Text
  tags          String           @default("[]") // JSON string 数组（项目惯例，用 safeJsonParse 解析）
  // 归属
  ownerId       String           // 上传者 / 生成者 userId
  owner         User             @relation(fields: [ownerId], references: [id])
  libraryType   MediaLibraryType @default(PERSONAL)
  teamId        String?          // 团队库归属（libraryType=TEAM 时必填，本期不启用）
  // 状态
  status        MediaStatus      @default(ACTIVE)
  // 时间
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([ownerId, createdAt])
  @@index([source])
  @@index([status])
  @@map("media_assets")
}
