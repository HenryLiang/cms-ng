# ===== 数据库 =====
# MySQL 8 现为外部中间件（不再随 docker-compose 启动）
# 本机开发：指向你机器上独立运行的 MySQL；生产：指向远程 MySQL hostname/IP
# 格式：mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:root123@localhost:3306/cms_ng"

# ===== Redis =====
# Redis 同样为外部中间件
# 无密码:    redis://HOST:PORT
# 有密码:    redis://:PASSWORD@HOST:PORT  (冒号后是密码)
REDIS_URL="redis://:PASSWORD@HOST:PORT"
# 单条 Redis 命令超时（毫秒）；缓存异常时业务按 fail-open/fail-closed 约定降级
REDIS_COMMAND_TIMEOUT_MS=5000

# ===== AI Provider =====
# 选择 LLM 提供商: 'deepseek' (默认) | 'kimi' | 'openai'
AI_PROVIDER="deepseek"

# DeepSeek (AI_PROVIDER=deepseek 时使用)
DEEPSEEK_API_KEY="your-deepseek-api-key"
DEEPSEEK_API_BASE="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-v4-pro"

# Kimi / Moonshot (AI_PROVIDER=kimi 时使用)
KIMI_API_KEY="your-kimi-api-key"
KIMI_API_BASE="https://api.kimi.com/coding/v1"
KIMI_MODEL="kimi-for-coding"

# OpenAI (AI_PROVIDER=openai 时使用)
OPENAI_API_KEY="your-openai-api-key"
OPENAI_API_BASE="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4o"

# ===== 应用配置 =====
PORT=3001
NODE_ENV=development
JWT_SECRET="your-jwt-secret-change-in-production"
JWT_EXPIRES_IN="30d"

# ===== 作者风格数据目录 =====
# 作者人设数据所在目录（每个子目录 = 一位作者，含 profile.json + system_prompt.md）。
# 不填则默认 <cwd>/data/authors（dev 是仓库根，prod 是 backend/）。
# 生产环境请手动把 data/authors/ 复制到部署机并指向其绝对路径，例如：
#   AUTHORS_DATA_DIR="/opt/cms-ng/data/authors"
# 该目录不进 git（已在 .gitignore），支持运行时动态增删作者（30s 缓存刷新）。
# 目录缺失或为空时，作者风格功能自动降级为默认生成方式，不影响内容生产。
# AUTHORS_DATA_DIR=""

# ===== Tavily Search =====
TAVILY_API_KEY="your-tavily-api-key"
TAVILY_SEARCH_DEPTH="advanced"   # Tavily 搜索深度: 'basic' | 'advanced'（默认 advanced）
TAVILY_MAX_RESULTS="5"           # Tavily 搜索默认返回结果数
TAVILY_MAX_RESULTS_LIMIT="10"    # Tavily 搜索最大结果数上限
SEARCH_PROVIDER="tavily"          # 联网搜索提供商: 'tavily' (推荐，兼容所有AI Provider) | 'kimi' (仅 AI_PROVIDER=kimi 时可用)

# ===== Seedream AI (ByteDance) =====
SEEDREAM_API_KEY="your-seedream-api-key"
SEEDREAM_API_BASE="https://ark.cn-beijing.volces.com/api/v3"
SEEDREAM_MODEL="doubao-seedream-5-0-260128"

# ===== 代理配置 =====
# 是否启用代理访问 Google Trends / BBC / Guardian 等海外 RSS 源
# 开发环境(大陆)设为 true，生产环境(新加坡等海外机房)设为 false
RSS_PROXY_ENABLED="false"
# HTTP_PROXY 仅在 RSS_PROXY_ENABLED=true 时生效
HTTP_PROXY="http://127.0.0.1:7890"

# ===== RSSHub =====
# 自部署 RSSHub 实例地址，用于聚合海外/国内 RSS 源
# dev: docker-compose up -d rsshub 后默认地址即下方
# prod: 指向独立部署的 RSSHub 或第三方 RSS 服务
RSS_HUB_URL="http://localhost:1200"

# ===== X (Twitter) 数据源 — twitterapi.io =====
# 用于选题：X 趋势榜单 + 热门账号最新推文。单 x-api-key 头认证，按次付费。
# 拉取纳入计费（缓存未命中时扣费，缓存命中免费；定价项 x_trending_fetch）。
TWITTERAPI_IO_API_KEY=""
TWITTERAPI_IO_BASE_URL="https://api.twitterapi.io"
# 可切换的趋势地域（WOEID 逗号分隔）：1=全球, 23424977=美国, 44418=英国
TWITTERAPI_IO_WOEIDS="1,23424977,44418"
# 大陆开发设 true（读下方 HTTP_PROXY 走代理）；新加坡生产设 false 直连
# 注意：原生 fetch 不读 HTTP_PROXY，此处单独用 undici ProxyAgent 显式挂代理
TWITTERAPI_IO_PROXY_ENABLED="false"

# ===== 当年今日 / 历史上的今天 — Wikipedia On This Day =====
# 用于选题：多地区（CN/HK/US/EU）历史上的今天事件。Wikipedia REST API 免费、无需 key。
# 大陆开发设 true（读下方 HTTP_PROXY 走代理访问 Wikipedia）；新加坡生产设 false 直连
# 注意：原生 fetch 不读 HTTP_PROXY，此处单独用 undici ProxyAgent 显式挂代理
WIKIPEDIA_PROXY_ENABLED="false"
# Wikipedia User-Agent 政策要求 UA 括号内必须包含 URL 或联系邮箱，否则会 403。
# 未配置时使用内置合规 UA；生产环境建议替换为真实联系信息。
# WIKIPEDIA_USER_AGENT="CMS-NG/1.0 (https://your-domain.com; admin@your-domain.com)"

# ===== Google Trends 实时趋势（Playwright 抓取）=====
# 用于选题：Google Trends 实时搜索趋势（Trending Now, hours=4/24/48/72）。
# 通过 Playwright 无头浏览器渲染 https://trends.google.com/trending 抓取，数据量
# 约 30+/地区（远多于 RSS 每日热搜的 ~10 条），但单条仅标题（无 traffic/新闻）。
# PLAYWRIGHT_ENABLED=false 时该源从 GET /sources 隐藏并回退到 RSS 每日源（fail-open）。
# 注意：需一次性主机安装 Chromium（生产为 host 进程，非容器）：
#   cd backend && npx playwright install --with-deps chromium
# （含 apt 系统库 libnss3/libatk1.0/libgbm1 等 + fonts-noto-cjk 渲染中文，约 170MB）
PLAYWRIGHT_ENABLED="false"
# 浏览器二进制缓存路径（不填则用 ~/.cache/ms-playwright）。生产建议指向项目目录，
# 避免与部署用户 home 耦合。
# PLAYWRIGHT_BROWSERS_PATH="/opt/cms-ng/playwright-browsers"
# 默认时间窗口（小时）：4/24/48/72。前端可在源参数覆盖。
GOOGLE_TRENDS_HOURS="24"
# 大陆开发设 true（读下方 HTTP_PROXY 走代理访问 Google）；海外生产设 false 直连。
# 注意：Playwright 不读 HTTP_PROXY 环境变量，需显式传入 chromium.launch({proxy})。
GOOGLE_TRENDS_REALTIME_PROXY_ENABLED="false"
# Playwright 抓取失败时是否回退到 RSS 每日 google-trends 源（返回 status:degraded）。
GOOGLE_TRENDS_REALTIME_FALLBACK_TO_RSS="true"
# Redis 缓存 TTL（秒），缓存完整抓取列表避免重复渲染页面。
GOOGLE_TRENDS_REALTIME_CACHE_TTL="60"

# ===== WordPress API 发布 =====
# WordPress REST API 自动发布配置
# Application Password 获取方式：WordPress 后台 → 用户 → 个人资料 → 应用程序密码
WORDPRESS_SITE_URL="https://your-site.com"
WORDPRESS_USERNAME="your-username"
WORDPRESS_APP_PASSWORD="xxxx xxxx xxxx xxxx xxxx xxxx"

# ===== 腾讯云 COS 对象存储 =====
# 公有读 + 私有写 bucket,前端和 WordPress 通过 https:// 直接读取
# 1. 在 https://console.cloud.tencent.com/cos 创建 bucket
# 2. 桶策略:公有读(读不需要签名),私有写
# 3. 在 CAM 创建子账号,只授予本 bucket 的 PutObject / GetObject / DeleteObject 权限
# 4. CORS: 允许 http://localhost:3000 和生产前端域名 GET
COS_SECRET_ID="your-cos-secret-id"
COS_SECRET_KEY="your-cos-secret-key"
COS_BUCKET="your-bucket-name-1300000000"
COS_REGION="ap-shanghai"
# 可选 — 不填则用默认 https://<bucket>.cos.<region>.myqcloud.com
# COS_BASE_URL="https://cdn.your-domain.com"

# ===== SMTP 邮件通知 =====
# 用于发送审稿、自动发布失败等通知邮件
# 常用配置示例：QQ 企业邮 / 163 / Gmail 等 SMTP 服务
SMTP_HOST="smtp.qq.com"
SMTP_PORT=465
SMTP_USER="your-email@qq.com"
SMTP_PASS="your-smtp-password-or-app-password"
SMTP_FROM="your-email@qq.com"
NOTIFICATION_EMAIL="ops@your-domain.com"

# ===== 应用基础 URL =====
# 后端服务地址（用于支付回调等）
APP_BASE_URL="http://localhost:3001"
# 前端地址（用于支付宝同步跳转）
FRONTEND_BASE_URL="http://localhost:3000"

# ===== Billing / Payment =====
BILLING_ENABLED=true
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
WECHAT_PAY_APP_ID=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_SERIAL_NO=
WECHAT_PAY_PRIVATE_KEY_PATH=

# ===== CORS =====
# 允许跨源请求的来源（逗号分隔）。开发环境默认允许 http://localhost:3000
# 也会被合并。生产环境如不配置则拒绝所有跨源请求（安全默认值）。
# 多个域名: CORS_ORIGINS="https://app.example.com,https://admin.example.com"
# CORS_ORIGINS="https://app.example.com"
